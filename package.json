{
  "name": "claudeclaw",
  "version": "1.1.0",
  "description": "Richard's trading-only agent for Polymarket paper trading and regime-trader equity operations",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "migrate": "tsx scripts/migrate.ts",
    "setup": "tsx scripts/setup.ts",
    "status": "tsx scripts/status.ts",
    "trading:status": "tsx scripts/trading-readiness.ts",
    "trading:benchmark": "tsx scripts/equity-benchmark-status.ts",
    "trading:benchmark:snapshot": "tsx scripts/equity-benchmark-snapshot.ts",
    "trading:pm2:write": "tsx scripts/regime-trader-pm2.ts",
    "poly:paper:status": "tsx scripts/poly-paper-readiness.ts",
    "poly:settled:calibration": "tsx scripts/poly-settled-calibration.ts",
    "poly:pnl:heartbeat": "tsx scripts/poly-pnl-heartbeat.ts",
    "poly:resolution:fetch-priority": "tsx scripts/fetch-resolutions.ts --limit 75",
    "poly:resolution:fetch-priority:register": "tsx scripts/register-poly-resolution-fetch-cron.ts",
    "poly:resolution:watch": "tsx scripts/poly-resolution-watch.ts",
    "poly:resolution:watch:register": "tsx scripts/register-poly-resolution-watch-cron.ts",
    "poly:settlement:impact": "tsx scripts/poly-settlement-impact.ts",
    "poly:open-mtm": "tsx scripts/poly-open-mtm-diagnostics.ts",
    "poly:ttl:report": "tsx scripts/poly-ttl-shadow-report.ts --days 14 --out docs/research/sprint-s2-ttl-filter-latest.md",
    "readiness:evidence": "tsx scripts/readiness-evidence.ts",
    "readiness:evidence:record": "tsx scripts/readiness-evidence.ts --record --history 14",
    "readiness:evidence:cron": "tsx scripts/register-readiness-evidence-cron.ts",
    "scheduler:status": "tsx scripts/check-scheduler-state.ts --summary",
    "scheduler:status:full": "tsx scripts/check-scheduler-state.ts",
    "overnight:agent": "tsx scripts/overnight-trading-agent.ts",
    "overnight:agent:register": "tsx scripts/register-overnight-trading-agent-cron.ts",
    "source:freshness:refresh": "tsx scripts/source-freshness-refresh.ts",
    "gate:status": "tsx scripts/gate-progress.ts",
    "gate:audit": "tsx scripts/gate-audit.ts",
    "capacity:status": "npm run status && npm run trading:status && npm run trading:benchmark && npm run poly:paper:status && npm run poly:settled:calibration && npm run poly:pnl:heartbeat && npm run poly:resolution:watch && npm run poly:settlement:impact && npm run poly:open-mtm && npm run scheduler:status && npm run source:freshness:refresh && npm run gate:status && npm run gate:audit && npm run readiness:evidence && tsx scripts/poly-ttl-shadow-report.ts",
    "agent:surface:check": "tsx scripts/check-agent-surface.ts",
    "agent:create": "bash scripts/agent-create.sh",
    "agent:start": "node dist/index.js --agent",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop ecosystem.config.cjs",
    "pm2:restart": "pm2 restart ecosystem.config.cjs",
    "pm2:logs": "pm2 logs"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.34",
    "@anthropic-ai/sdk": "^0.88.0",
    "@google/genai": "^1.44.0",
    "@hono/node-server": "^1.19.9",
    "@slack/web-api": "^7.14.1",
    "better-sqlite3": "^11.8.1",
    "cron-parser": "^5.5.0",
    "grammy": "^1.34.0",
    "hono": "^4.12.3",
    "js-yaml": "^4.1.1",
    "luxon": "^3.7.2",
    "openai": "^6.34.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "qrcode-terminal": "^0.12.0",
    "whatsapp-web.js": "^1.34.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/js-yaml": "^4.0.9",
    "@types/luxon": "^3.7.1",
    "@types/node": "^22.10.0",
    "@types/qrcode-terminal": "^0.12.2",
    "@vitest/coverage-v8": "^2.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "vitest": {
    "environment": "node",
    "include": [
      "src/**/*.test.ts"
    ]
  }
}
