{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "src/poly/migration.test.ts", "src/poly/calibration-migration.test.ts", "src/poly/strategy-versioning-migration.test.ts", "src/poly/regime-migration.test.ts", "src/poly/research-ingest-migration.test.ts", "src/poly/backtest-migration.test.ts", "src/poly/scan-runs-migration.test.ts"]
}
